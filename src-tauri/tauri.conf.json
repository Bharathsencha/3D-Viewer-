{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "3D File Viewer",
  "version": "0.1.6",
  "identifier": "com.bharathsencha.3dviewer",
  "build": {
    "frontendDist": "../tauri-dist",
    "beforeDevCommand": "npm run build_tauri",
    "beforeBuildCommand": "npm run build_tauri"
  },
  "app": {
    "windows": [
      {
        "title": "3D Viewer",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
